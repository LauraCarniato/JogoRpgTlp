<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefWidth="800"
            prefHeight="600"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.jogorpgtlp.controller.CombateController"
            style="-fx-background-color: black;">

    <children>

        <!-- Fundo -->
        <ImageView fx:id="mapaCombate"
                   fitWidth="800"
                   fitHeight="600"
                   preserveRatio="false"
                   visible="false" />

        <!-- Jogador -->
        <ImageView fx:id="playerCombate"
                   fitWidth="140"
                   fitHeight="140"
                   preserveRatio="true"
                   layoutX="330"
                   layoutY="335"
                   visible="false" />

        <!-- Goblin pequeno -->
        <ImageView fx:id="goblinCombate"
                   fitWidth="140"
                   fitHeight="140"
                   preserveRatio="true"
                   layoutX="330"
                   layoutY="220"
                   visible="false" />

        <!-- Goblin grandão do diálogo -->
        <ImageView fx:id="goblin"
                   fitWidth="720"
                   fitHeight="720"
                   preserveRatio="true"
                   AnchorPane.leftAnchor="40.0"
                   AnchorPane.rightAnchor="40.0"
                   AnchorPane.topAnchor="-40.0" />

        <!-- Diálogo -->
        <!-- Caixa de diálogo -->

            <Label fx:id="dialogo"
                   text=""
                   layoutX="35"
                   layoutY="470"
                   prefWidth="730"
                   prefHeight="95"
                   alignment="CENTER_LEFT"
                   wrapText="true"
                   style="-fx-text-fill: white;
                          -fx-font-size: 24px;
                          -fx-font-weight: bold;
                          -fx-background-color: rgba(0,0,0,0.85);
                          -fx-background-radius: 10;
                          -fx-border-color: white;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-padding: 15;" />

        <!-- Prêmios -->
        <Label fx:id="premiosLabel"
       text=""
       layoutX="90"
       layoutY="350"
       prefWidth="560"
       prefHeight="160"
       alignment="CENTER"
       visible="false"
       wrapText="true"
       style="-fx-text-fill: white;
              -fx-font-size: 20px;
              -fx-font-weight: bold;
              -fx-background-color: rgba(0,0,0,0.65);
              -fx-background-radius: 10;
              -fx-padding: 15;" />

        <!-- Vida -->
        <Label fx:id="vidaJogadorLabel"
               text="Jogador: 30/30"
               layoutX="45"
               layoutY="525"
               visible="false"
               style="-fx-text-fill: white;
                      -fx-font-size: 22px;
                      -fx-font-weight: bold;" />

        <Label fx:id="vidaGoblinLabel"
               text="Goblin: 25/25"
               layoutX="580"
               layoutY="25"
               visible="false"
               style="-fx-text-fill: white;
                      -fx-font-size: 22px;
                      -fx-font-weight: bold;" />

        <!-- Mensagens -->
        <Label fx:id="mensagemCombate"
               text=""
               layoutX="575"
               layoutY="260"
               prefWidth="200"
               prefHeight="80"
               visible="false"
               wrapText="true"
               style="-fx-text-fill: white;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;
                      -fx-background-color: rgba(0,0,0,0.55);
                      -fx-background-radius: 8;
                      -fx-padding: 10;" />

        <!-- Cartas do Goblin -->
        <ImageView fx:id="cartaGoblin1" fitWidth="280" fitHeight="320" layoutX="20" layoutY="55" preserveRatio="true" visible="false" />
        <ImageView fx:id="cartaGoblin2" fitWidth="280" fitHeight="320" layoutX="120" layoutY="55" preserveRatio="true" visible="false" />
        <ImageView fx:id="cartaGoblin3" fitWidth="280" fitHeight="320" layoutX="220" layoutY="55" preserveRatio="true" visible="false" />
        <ImageView fx:id="cartaGoblin4" fitWidth="280" fitHeight="320" layoutX="320" layoutY="55" preserveRatio="true" visible="false" />
        <ImageView fx:id="cartaGoblin5" fitWidth="280" fitHeight="320" layoutX="420" layoutY="55" preserveRatio="true" visible="false" />

        <!-- Cartas do Jogador -->
        <ImageView fx:id="cartaEspada"
           fitWidth="280"
           fitHeight="320"
           layoutX="120"
           layoutY="430"
           preserveRatio="true"
           visible="false"
           onMouseClicked="#usarEspada"/>


    <ImageView fx:id="cartaCura"
               fitWidth="280"
               fitHeight="320"
               layoutX="220"
               layoutY="430"
               preserveRatio="true"
               visible="false"
               onMouseClicked="#usarCura"/>


    <ImageView fx:id="cartaEscudo"
               fitWidth="280"
               fitHeight="320"
               layoutX="320"
               layoutY="430"
               preserveRatio="true"
               visible="false"
               onMouseClicked="#usarEscudo"/>


    <ImageView fx:id="cartaFogo"
               fitWidth="280"
               fitHeight="320"
               layoutX="420"
               layoutY="430"
               preserveRatio="true"
               visible="false"
               onMouseClicked="#usarFogo"/>


    <ImageView fx:id="cartaCongelamento"
               fitWidth="280"
               fitHeight="320"
               layoutX="520"
               layoutY="430"
               preserveRatio="true"
               visible="false"
               onMouseClicked="#usarCongelamento"/>

    </children>

</AnchorPane>