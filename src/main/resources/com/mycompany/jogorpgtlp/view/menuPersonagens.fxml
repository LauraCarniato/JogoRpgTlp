<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="20.0"
      style="-fx-background-color: #800000"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.jogorpgtlp.controller.MenuPersonagensController">

    <children>

        <ListView fx:id="listaPersonagens"
                  prefWidth="400"
                  prefHeight="300" />

        <HBox alignment="CENTER" spacing="10">

            <Button text="Entrar no jogo"
                    onAction="#entrarNoJogo"
                    style="-fx-background-color: #f0e68c" />

            <Button text="Criar novo personagem"
                    onAction="#criarPersonagem"
                    style="-fx-background-color: #f0e68c" />

            <Button text="Voltar"
                    onAction="#voltar"
                    style="-fx-background-color: #f0e68c" />

        </HBox>

    </children>

    <padding>
        <Insets bottom="20.0"
                left="20.0"
                right="20.0"
                top="20.0" />
    </padding>

</VBox>
